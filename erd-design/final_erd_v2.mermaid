erDiagram
    users ||--o{ materials : "uploads"
    users ||--o{ interactions : "interacts"
    users ||--o{ groups : "creates"
    users ||--o{ members : "belongs_to"
    users ||--o{ chats : "sends"
    users ||--o{ schedules : "manages"
    
    materials ||--o{ interactions : "has"
    groups ||--o{ members : "has_members"
    groups ||--o{ chats : "has_messages"
    groups ||--o{ schedules : "has_events"

    users {
        int id PK
        string login_id
        string email
        string password_hash
        string nickname
        string identity_info
        string status
        timestamp created_at
        timestamp deleted_at
    }

    materials {
        int id PK
        int user_id FK
        string category
        string title
        text content
        string file_url
        int view_count
        string status
        timestamp created_at
    }

    interactions {
        int id PK
        int user_id FK
        int material_id FK
        int parent_id FK
        text content
        string type
        boolean is_public
        timestamp created_at
    }

    groups {
        int id PK
        string unique_code
        string name
        int creator_id FK
        string status
        timestamp created_at
    }

    members {
        int group_id PK, FK
        int user_id PK, FK
        string role
        string status
        timestamp joined_at
    }

    chats {
        int id PK
        int group_id FK
        int user_id FK
        text message
        string message_type
        timestamp sent_at
    }

    schedules {
        int id PK
        int user_id FK
        int group_id FK
        string title
        datetime start_at
        datetime end_at
        string status
    }
